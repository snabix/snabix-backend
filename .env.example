APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080
FRONTEND_URL=http://127.0.0.1:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:3001,127.0.0.1:3000,127.0.0.1:3001
FRONTEND_RESET_PASSWORD_URL=${FRONTEND_URL}/auth/reset-password

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
SYSTEM_LOGGING_ENABLED=true
SYSTEM_LOGGING_HTTP_REQUESTS_ENABLED=true
SYSTEM_LOGGING_HTTP_SAFE_REQUESTS=false
SYSTEM_LOGGING_HTTP_UNSAFE_REQUESTS=true
SYSTEM_LOGGING_HTTP_CLIENT_ERRORS=true
SYSTEM_LOGGING_HTTP_SERVER_ERRORS=true
SYSTEM_LOGGING_HTTP_SLOW_REQUEST_MS=1500
SYSTEM_LOGGING_RETENTION_DAYS=30

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=snabix
DB_USERNAME=root
DB_PASSWORD=1234
DB_TEST_HOST=db-test
DB_TEST_PORT=5432
DB_TEST_DATABASE=snabix_test
DB_TEST_USERNAME=root
DB_TEST_PASSWORD=1234

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=rabbitmq

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

RABBITMQ_CONNECTION=default
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=notifications
RABBITMQ_WORKER=default
QUEUE_WORK_QUEUES=notifications
QUEUE_FAILED_RETENTION_HOURS=168

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@snabix.local"
MAIL_FROM_NAME="${APP_NAME}"
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

L5_SWAGGER_GENERATE_ALWAYS=true
