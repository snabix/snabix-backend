APP_NAME=SNABIX
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:3001,127.0.0.1:3000,127.0.0.1:3001
FRONTEND_RESET_PASSWORD_URL=${FRONTEND_URL}/reset-password

CATALOG_IMPORT_PROM_NETWORK_ENABLED=false
CATALOG_IMPORT_PROM_RIGHTS_REFERENCE=
CATALOG_IMPORT_PROM_VERSION=prom-dom-v1
CATALOG_IMPORT_PROM_URL=https://prom.ua/consumer-goods
CATALOG_IMPORT_MAX_RESPONSE_BYTES=5242880
CATALOG_IMPORT_USER_AGENT=SnabixCatalogImporter/1.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
SYSTEM_LOGGING_ENABLED=true
SYSTEM_LOGGING_HTTP_REQUESTS_ENABLED=true
SYSTEM_LOGGING_HTTP_SAFE_REQUESTS=false
SYSTEM_LOGGING_HTTP_UNSAFE_REQUESTS=true
SYSTEM_LOGGING_HTTP_CLIENT_ERRORS=true
SYSTEM_LOGGING_HTTP_SERVER_ERRORS=true
SYSTEM_LOGGING_HTTP_SLOW_REQUEST_MS=1500
SYSTEM_LOGGING_RETENTION_DAYS=30
STORAGE_CLEANUP_ENABLED=true
STORAGE_CLEANUP_LOGS_RETENTION_DAYS=14
STORAGE_CLEANUP_API_DOCS_RETENTION_DAYS=30
STORAGE_CLEANUP_TEMP_UPLOADS_RETENTION_DAYS=2
STORAGE_CLEANUP_MEDIA_LIBRARY_TEMP_RETENTION_DAYS=2
STORAGE_CLEANUP_DEBUGBAR_RETENTION_DAYS=7

# Local docker defaults only. Never copy DB root/1234, RabbitMQ guest/guest or
# SNABIX_BOT_SERVICE_TOKEN=change-me to staging/production.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=snabix
DB_USERNAME=root
DB_PASSWORD=1234

DB_TEST_HOST=db-test
DB_TEST_PORT=5433
DB_TEST_DATABASE=snabix_test
DB_TEST_USERNAME=root
DB_TEST_PASSWORD=1234

SESSION_DRIVER=database
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=rabbitmq

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

RABBITMQ_CONNECTION=default
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=notifications
RABBITMQ_WORKER=default

QUEUE_WORK_QUEUES=notifications
QUEUE_FAILED_RETENTION_HOURS=168

SNABIX_BOOTSTRAP_ADMIN_NAME=Admin
SNABIX_BOOTSTRAP_ADMIN_EMAIL=
SNABIX_BOOTSTRAP_ADMIN_PASSWORD=

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@snabix.local"
MAIL_FROM_NAME="${APP_NAME}"
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

SNABIX_BOT_SERVICE_TOKEN=change-me

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
