# Copy this file outside Git for each release and replace every image with a
# tag tied to one commit or, preferably, an OCI digest. Never use latest.
BACKEND_IMAGE=ghcr.io/example/snabix-backend:sha-0123456789abcdef0123456789abcdef01234567
FRONTEND_IMAGE=ghcr.io/example/snabix-frontend:sha-0123456789abcdef0123456789abcdef01234567
BOT_IMAGE=ghcr.io/example/snabix-telegram-bot:sha-0123456789abcdef0123456789abcdef01234567

PRODUCTION_ENV_FILE=./deploy/production.env.example
EDGE_BIND_ADDRESS=127.0.0.1
EDGE_PORT=8080
