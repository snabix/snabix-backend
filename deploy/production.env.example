# This file documents required keys only. Store the real file outside Git,
# restrict it to the deploy user and run the production secret guard.
APP_NAME=SNABIX
APP_ENV=production
APP_DEBUG=false
APP_KEY=replace-with-generated-laravel-key
APP_URL=https://api.staging.example.com
BACKEND_HOST=api.staging.example.com
FRONTEND_URL=https://staging.example.com
FRONTEND_URLS=https://staging.example.com
FRONTEND_RESET_PASSWORD_URL=https://staging.example.com/reset-password
SANCTUM_STATEFUL_DOMAINS=staging.example.com

LOG_CHANNEL=stderr
LOG_LEVEL=info
SCHEDULER_HEALTH_ENABLED=true

DB_CONNECTION=pgsql
DB_HOST=postgres.private
DB_PORT=5432
DB_DATABASE=snabix
DB_USERNAME=replace-with-dedicated-database-user
DB_PASSWORD=replace-with-generated-database-password
DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=43200
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.staging.example.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis.private
REDIS_PASSWORD=replace-with-generated-redis-password
REDIS_PORT=6379

QUEUE_CONNECTION=rabbitmq
QUEUE_WORK_QUEUES=notifications,media-maintenance
RABBITMQ_HOST=rabbitmq.private
RABBITMQ_PORT=5672
RABBITMQ_USER=replace-with-dedicated-rabbitmq-user
RABBITMQ_PASSWORD=replace-with-generated-rabbitmq-password
RABBITMQ_VHOST=/snabix
RABBITMQ_QUEUE=notifications
RABBITMQ_WORKER=default

FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=replace-with-scoped-storage-key
AWS_SECRET_ACCESS_KEY=replace-with-generated-storage-secret
AWS_DEFAULT_REGION=replace-with-storage-region
AWS_BUCKET=replace-with-private-bucket
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.private
MAIL_PORT=587
MAIL_USERNAME=replace-with-smtp-user
MAIL_PASSWORD=replace-with-generated-smtp-password
MAIL_FROM_ADDRESS=noreply@staging.example.com
MAIL_FROM_NAME=SNABIX

SNABIX_BOT_TOKEN=replace-with-generated-telegram-token
SNABIX_BOT_MODE=polling
SNABIX_BOT_SERVICE_TOKEN=replace-with-shared-bot-backend-service-token
SNABIX_BACKEND_BASE_URL=http://web:8080/api/v1
SNABIX_BACKEND_SERVICE_TOKEN=replace-with-shared-bot-backend-service-token
SNABIX_ADMIN_PANEL_URL=https://api.staging.example.com/admin
SNABIX_ADMIN_TELEGRAM_IDS=
SNABIX_BOT_HEALTH_HOST=0.0.0.0
SNABIX_BOT_HEALTH_PORT=9001
SNABIX_LOG_LEVEL=INFO
