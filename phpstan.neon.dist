includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    level: 9

    paths:
        - app
        - bootstrap
        - config
        - database/factories
        - database/seeders
        - routes
        - tests

    tmpDir: storage/phpstan

    excludePaths:
        analyse:
            - bootstrap/cache/*
            - storage/*
