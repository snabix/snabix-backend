{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "snabix/backend",
    "type": "project",
    "description": "Backend API and Filament administration for the Snabix regional marketplace.",
    "keywords": ["snabix", "marketplace", "classifieds", "laravel", "filament"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "ext-dom": "*",
        "ans-group/laravel-health-check": "^3.0",
        "bezhansalleh/filament-shield": "^4.2",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-media-library-plugin": "^5.0",
        "halaxa/json-machine": "^1.2",
        "laravel-lang/lang": "^15.29",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.10.1",
        "predis/predis": "^3.4",
        "spatie/laravel-data": "^4.22",
        "spatie/laravel-medialibrary": "^11.22",
        "vladimir-yuldashev/laravel-queue-rabbitmq": "^14.5"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.2",
        "dedoc/scramble": "^0.13.22",
        "fakerphp/faker": "^1.23",
        "friendsofphp/php-cs-fixer": "^3.95",
        "larastan/larastan": "^3.0",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.50"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:work rabbitmq --queue=notifications,media-maintenance --tries=3 --timeout=60 --sleep=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "stan": [
            "@php vendor/bin/phpstan analyse --memory-limit=1G"
        ],
        "check": [
            "@php vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --using-cache=no --dry-run --sequential --verbose",
            "@php vendor/bin/phpstan analyse --memory-limit=1G",
            "@php artisan scramble:analyze"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
